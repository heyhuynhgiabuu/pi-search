{
	"name": "@heyhuynhgiabuu/pi-search",
	"version": "0.2.1",
	"description": "Unified search toolkit for pi — web search, code search, docs lookup, and GitHub code search in one extension.",
	"author": "huynhgiabuu",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/buddingnewinsights/pi-search.git"
	},
	"homepage": "https://github.com/buddingnewinsights/pi-search#readme",
	"bugs": {
		"url": "https://github.com/buddingnewinsights/pi-search/issues"
	},
	"publishConfig": {
		"access": "public"
	},
	"keywords": [
		"pi-package",
		"pi",
		"pi-extension",
		"search",
		"web-search",
		"code-search",
		"documentation",
		"context7",
		"exa",
		"grepapp",
		"grepsearch",
		"websearch",
		"codesearch"
	],
	"peerDependencies": {
		"@mariozechner/pi-coding-agent": "*"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.3.5",
		"@types/node": "^20.0.0",
		"typescript": "^5.0.0",
		"vitest": "^4.0.18"
	},
	"dependencies": {
		"@sinclair/typebox": "^0.34.0"
	},
	"scripts": {
		"build": "tsc",
		"typecheck": "tsc --noEmit",
		"lint": "biome check src/",
		"lint:fix": "biome check --fix src/",
		"test": "vitest run --passWithNoTests",
		"test:watch": "vitest --passWithNoTests"
	},
	"pi": {
		"extensions": [
			"./src/index.ts"
		]
	}
}
